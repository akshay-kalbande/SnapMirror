{
  "functions": [
    {
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ],
      "source": "functions"
    }
  ],
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "instagramclone-bbbee",
          "appId": "1:858838546933:android:f0a1fcc16e19c68fb048bc",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "instagramclone-bbbee",
          "configurations": {
            "android": "1:858838546933:android:f0a1fcc16e19c68fb048bc",
            "ios": "1:858838546933:ios:e2907590ed0f819ab048bc",
            "macos": "1:858838546933:ios:e2907590ed0f819ab048bc",
            "web": "1:858838546933:web:6d4407fc3f16a61fb048bc",
            "windows": "1:858838546933:web:327c615a04babdd4b048bc"
          }
        }
      }
    }
  }
}